{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "andersogkristine-no",
	"compatibility_date": "2026-05-25",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"kv_namespaces": [
		{
			"binding": "WEDDING_CACHE",
