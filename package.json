{
  "name": "wedding-site-cloudflare-worker",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "bun run src/scripts/prebuild.ts && astro dev",
    "build": "bun run src/scripts/prebuild.ts && astro build",
    "deploy": "bun run build && bunx wrangler deploy",
    "preview": "astro preview",
    "lint": "biome lint .",
    "format": "biome format .",
    "astro": "astro",
    "dev:clean": "rm -rf .wrangler/state/v3 .astro"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.7.0",
    "@astrojs/react": "^5.0.7",
    "@notionhq/client": "^5.22.0",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^6.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@cloudflare/workers-types": "^4.20260615.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "bun-types": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
