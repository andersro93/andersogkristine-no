{
  "name": "wedding-site-cloudflare-worker",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "bun run src/scripts/prebuild.ts && astro dev",
    "build": "bun run src/scripts/prebuild.ts && astro build",
    "deploy": "bun run build && bunx wrangler deploy",
    "preview": "astro preview",
    "lint": "biome lint .",
    "format": "biome format .",
    "astro": "astro",
    "dev:clean": "rm -rf .wrangler/state/v3 .astro"
  },
  "dependencies": {
    "@astrojs/cloudflare": "14.1.3",
    "@astrojs/react": "6.0.1",
    "@notionhq/client": "5.23.2",
    "@tailwindcss/vite": "4.3.3",
    "astro": "7.1.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "4.3.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@cloudflare/workers-types": "5.20260719.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "bun-types": "1.3.14",
    "typescript": "7.0.2"
  }
}
