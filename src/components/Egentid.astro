---
import { env } from 'cloudflare:workers';
import { weddingConfig } from '../config';
import { fetchEgentidData, type Contributor } from '../services/notion';

const context = Astro.locals?.cfContext;

let contributors: Contributor[] = [];
try {
  contributors = await fetchEgentidData(env as Env, context);
} catch (err) {
  console.error("Error loading egentid from Notion:", err);
  contributors = weddingConfig.egentid.contributors;
}

const { egentid } = weddingConfig;
const initialContributor = contributors[0] || egentid.contributors[0];
---

<section id="egentid" class="py-20 px-4 md:px-8 bg-brand-bg/40 border-b border-brand-title/5 scroll-mt-6" data-contributors={JSON.stringify(contributors)}>
  <div class="max-w-6xl mx-auto">
    
    <!-- Title & Subtitle -->
    <div class="text-center max-w-2xl mx-auto mb-16 space-y-3">
      <h2>{egentid.title}</h2>
      <div class="w-12 h-[1px] bg-brand-title/30 mx-auto"></div>
      <p class="text-lead">{egentid.subtitle}</p>
      <p class="text-body max-w-lg mx-auto pt-2">
        {egentid.description}
      </p>
    </div>

    <!-- 4-Grid Polaroid Section -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto mb-12">
      {contributors.map((c, index) => {
        // Playful slightly rotated polaroids
        const rotations = ['-rotate-1', 'rotate-2', '-rotate-2', 'rotate-1'];
        const rotClass = rotations[index % rotations.length];
        const isFirst = index === 0;

        return (
          <div 
            data-contributor-id={c.id}
            class={`relative bg-white p-3 pb-8 rounded-sm shadow-md border ${
              isFirst ? 'border-brand-title ring-2 ring-brand-title/15 scale-105 z-10 rotate-0' : 'border-gray-200/60 ' + rotClass
            } hover:rotate-0 hover:scale-105 hover:z-20 hover:shadow-xl transition-all duration-300 cursor-pointer group`}
          >
            <!-- Photo Frame (looks for image, falls back to decorative avatar letter) -->
            <div class="aspect-square w-full rounded-xs bg-brand-title/5 border border-gray-100 overflow-hidden flex items-center justify-center relative">
              <img 
                src={c.photo} 
                alt={c.name}
                class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-300"
                onload="this.classList.remove('opacity-0');"
                onerror="this.style.display='none'; this.nextElementSibling.classList.remove('hidden');"
              />
              <div class="hidden w-full h-full flex flex-col items-center justify-center bg-brand-title/10 text-brand-title/80 select-none">
                <span class="font-wedding text-4xl">{c.name.charAt(0)}</span>
                <span class="text-[9px] uppercase tracking-wider font-semibold opacity-75 font-sans mt-1">Legg til foto</span>
              </div>
            </div>

            <!-- Polaroid Signature Label -->
            <div class="text-center mt-3 select-none">
              <span class="font-wedding text-2xl text-brand-title group-hover:text-brand-text transition-colors">
                {c.name} {c.emoji || ''}
              </span>
            </div>
          </div>
        );
      })}
    </div>

    <!-- Inline Suggestions Card (Dynamically updated) -->
    <div id="egentid-content-card" class="max-w-2xl mx-auto bg-brand-bg rounded-xl border border-brand-title/15 shadow-sm p-6 md:p-8 min-h-[250px] scroll-mt-24">
      
      <!-- Framing decorative line -->
      <div id="egentid-content-container" class="opacity-100 transition-opacity duration-200 ease-in-out space-y-6">
        <div>
          <h3 id="egentid-role" class="mb-2">
            {initialContributor.role}
          </h3>
          <p id="egentid-desc" class="text-lead text-brand-text/75 font-semibold">
            {initialContributor.description}
          </p>
        </div>

        <div class="w-full h-[1px] bg-brand-title/10"></div>

        <ul id="egentid-list" class="space-y-3">
          {initialContributor.suggestions.map((s) => (
            <li class="flex items-start gap-3 text-brand-text/90 text-sm leading-relaxed font-light">
              <span class="text-brand-title text-sm mt-0.5 select-none">&#9670;</span>
              <div class="flex-1">
                <span set:html={s.text}></span>
                {s.locationId && (
                  <a
                    href={`/kart?loc=${s.locationId}`}
                    class="inline-flex items-center gap-0.5 text-xs font-semibold text-brand-title hover:text-brand-text hover:underline ml-1.5 select-none transition-colors"
                  >
                    <span>📍 Se kart</span>
                  </a>
                )}
              </div>
            </li>
          ))}
        </ul>
      </div>

    </div>

  </div>
</section>

<script>
  const section = document.getElementById('egentid');
  const contributors = JSON.parse(section?.getAttribute('data-contributors') || '[]');
  const cards = document.querySelectorAll('[data-contributor-id]');
  const titleEl = document.getElementById('egentid-role');
  const descEl = document.getElementById('egentid-desc');
  const listEl = document.getElementById('egentid-list');
  const container = document.getElementById('egentid-content-container');

  cards.forEach(card => {
    card.addEventListener('click', () => {
      const id = card.getAttribute('data-contributor-id');
      const contributor = contributors.find(c => c.id === id);
      if (!contributor) return;

      // Update active polaroid styling
      const rotations = ['-rotate-1', 'rotate-2', '-rotate-2', 'rotate-1'];
      cards.forEach((c, idx) => {
        c.classList.remove('border-brand-title', 'ring-2', 'ring-brand-title/15', 'scale-105', 'z-10', 'rotate-0');
        c.classList.add('border-gray-200/60', rotations[idx % rotations.length]);
      });
      card.classList.add('border-brand-title', 'ring-2', 'ring-brand-title/15', 'scale-105', 'z-10', 'rotate-0');
      card.classList.remove('border-gray-200/60', '-rotate-1', 'rotate-2', '-rotate-2', 'rotate-1');

      // Update suggestion content card with a smooth fade
      if (container) {
        container.style.opacity = '0';
        setTimeout(() => {
          if (titleEl) titleEl.innerText = contributor.role;
          if (descEl) descEl.innerText = contributor.description;
          
          if (listEl) {
            listEl.innerHTML = contributor.suggestions
              .map(s => `
                <li class="flex items-start gap-3 text-brand-text/90 text-sm leading-relaxed font-light">
                  <span class="text-brand-title text-sm mt-0.5 select-none">&#9670;</span>
                  <div class="flex-1">
                    <span>${s.text}</span>
                    ${s.locationId ? `
                      <a
                        href="/kart?loc=${s.locationId}"
                        class="inline-flex items-center gap-0.5 text-xs font-semibold text-brand-title hover:text-brand-text hover:underline ml-1.5 select-none transition-colors"
                      >
                        <span>📍 Se kart</span>
                      </a>
                    ` : ''}
                  </div>
                </li>
              `).join('');
          }
          container.style.opacity = '1';
        }, 150);
      }

      // Smooth scroll to the suggestions card
      const contentCard = document.getElementById('egentid-content-card');
      if (contentCard) {
        setTimeout(() => {
          contentCard.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 180);
      }
    });
  });
</script>
