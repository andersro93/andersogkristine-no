---
import { weddingConfig } from '../config';
---

<section id="location" class="py-20 px-4 md:px-8 bg-brand-bg/40 border-b border-brand-title/5">
  <div class="max-w-6xl mx-auto">
    
    <div class="text-center max-w-2xl mx-auto mb-16 space-y-3">
      <h2 class="font-wedding text-5xl md:text-6xl text-brand-title">Sted & Overnatting</h2>
      <div class="w-12 h-[1px] bg-brand-title/30 mx-auto"></div>
      <p class="font-sans text-xs uppercase tracking-widest text-brand-text/80 font-medium">Hvor det skjer og hvor dere kan bo</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-stretch">
      
      <!-- Venue & Map column -->
      <div class="flex flex-col space-y-6 bg-brand-bg p-6 md:p-8 rounded-xl border border-brand-title/10 shadow-xs">
        <div class="space-y-3">
          <p class="text-xs uppercase tracking-widest text-brand-title/80 font-semibold">Selskapslokale</p>
          <h3 class="font-serif text-2xl text-brand-title font-semibold">{weddingConfig.venue.name}</h3>
          <p class="font-sans text-sm text-brand-text/90 font-light leading-relaxed">
            {weddingConfig.venue.address}
          </p>
          
          <a href={weddingConfig.venue.googleMapsLink} 
             target="_blank" 
             rel="noopener noreferrer" 
             class="inline-flex items-center gap-2 text-xs uppercase tracking-wider font-semibold text-brand-title hover:text-brand-text transition-colors mt-2 group">
            <span>Veibeskrivelse i Google Maps</span>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
            </svg>
          </a>
        </div>

        <!-- Embedded Map -->
        {weddingConfig.venue.embedMapSrc && (
          <div class="relative w-full h-[300px] md:h-[350px] rounded-lg overflow-hidden border border-brand-title/10 shadow-inner group">
            <iframe 
              src={weddingConfig.venue.embedMapSrc} 
              class="absolute inset-0 w-full h-full border-0 grayscale hover:grayscale-0 transition-all duration-700" 
              allowfullscreen="" 
              loading="lazy" 
              referrerpolicy="no-referrer-when-downgrade"
              title="Venue location map"
            ></iframe>
          </div>
        )}
      </div>

      <!-- Accommodations column -->
      <div class="flex flex-col justify-between space-y-8 bg-brand-bg p-6 md:p-8 rounded-xl border border-brand-title/10 shadow-xs">
        <div class="space-y-6">
          <div>
            <p class="text-xs uppercase tracking-widest text-brand-title/80 font-semibold mb-2">Overnattingsforslag</p>
            <p class="font-sans text-sm text-brand-text/80 font-light leading-relaxed">
              Vi anbefaler følgende hotell hvis du har tenkt å sjekke inn på hotell
            </p>
          </div>

          <div class="space-y-6">
            {weddingConfig.accommodations.map((hotel) => (
              <div class="p-5 rounded-lg bg-brand-bg/60 border border-brand-title/5 hover:border-brand-title/15 transition-all duration-300 space-y-3">
                <div class="flex items-baseline justify-between flex-wrap gap-2">
                  <h4 class="font-serif text-xl text-brand-title font-semibold">{hotel.name}</h4>
                  <span class="text-xs font-semibold px-2 py-0.5 bg-brand-title/10 text-brand-title rounded-full font-sans">
                    {hotel.distance}
                  </span>
                </div>
                <p class="font-sans text-sm text-brand-text/85 font-light leading-relaxed">
                  {hotel.description}
                </p>
                {hotel.link && (
                  <a href={hotel.link} 
                     target="_blank" 
                     rel="noopener noreferrer" 
                     class="inline-flex items-center gap-1.5 text-xs font-semibold text-brand-title hover:text-brand-text transition-colors group">
                    <span>Besøk nettside</span>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3 h-3 group-hover:translate-x-0.5 transition-transform">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                    </svg>
                  </a>
                )}
              </div>
            ))}
          </div>
        </div>

        <div class="pt-4 border-t border-brand-title/10 text-center">
          <p class="font-sans text-xs text-brand-text/70 italic">
            Trenger du hjelp med transport eller bestilling? Ta gjerne kontakt med oss!
          </p>
        </div>
      </div>

    </div>

  </div>
</section>
