---
import { weddingConfig } from '../config';

// Helper to return custom SVG paths based on icon identifier
const getIconSvg = (iconName?: string) => {
  switch (iconName) {
    case 'church':
      return `
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7">
          <path stroke="none" d="M0 0h24v24H0z" fill="none" />
          <path d="M3 21l18 0" />
          <path d="M10 21v-4a2 2 0 0 1 4 0v4" />
          <path d="M10 5l4 0" />
          <path d="M12 3l0 5" />
          <path d="M6 21v-7m-2 2l8 -8l8 8m-2 -2v7" />
        </svg>
      `;
    case 'ring':
      return `
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7">
          <path stroke="none" d="M0 0h24v24H0z" fill="none" />
          <path d="M12 16m-4 0a4 4 0 1 0 8 0a4 4 0 1 0 -8 0" />
          <path d="M12 12l-2 -3l2 -3l2 3z" />
        </svg>
      `;
    case 'camera':
      return `
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7">
          <path stroke="none" d="M0 0h24v24H0z" fill="none" />
          <path d="M5 7h1a2 2 0 0 0 2 -2a1 1 0 0 1 1 -1h6a1 1 0 0 1 1 1a2 2 0 0 0 2 2h1a2 2 0 0 1 2 2v9a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-9a2 2 0 0 1 2 -2" />
          <path d="M9 13a3 3 0 1 0 6 0a3 3 0 1 0 -6 0" />
        </svg>
      `;
    case 'social':
      return `
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7">
          <path stroke="none" d="M0 0h24v24H0z" fill="none" />
          <path d="M8 16l2 -6l6 -2l-2 6z" />
          <path d="M12 12m-9 0a9 9 0 1 0 18 0a9 9 0 1 0 -18 0" />
          <path d="M12 3l0 2" />
          <path d="M12 19l0 2" />
          <path d="M3 12l2 0" />
          <path d="M19 12l2 0" />
        </svg>
      `;
    case 'glass':
      return `
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7">
          <path stroke="none" d="M0 0h24v24H0z" fill="none" />
          <path d="M8 21l8 0" />
          <path d="M12 15l0 6" />
          <path d="M17 3l-10 0l0 6a5 5 0 0 0 10 0l0 -6z" />
          <path d="M6 10l12 0" />
        </svg>
      `;
    case 'food':
      return `
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7">
          <path stroke="none" d="M0 0h24v24H0z" fill="none" />
          <path d="M4 3h3v7a3 3 0 0 1 -3 3v8h-1v-8a3 3 0 0 1 -3 -3v-7h1v4h1v-4h1v4h1v-4z" />
          <path d="M18 11h3v-8h-3a4 4 0 0 0 -4 4v4h1" />
          <path d="M18 11v10" />
        </svg>
      `;
    case 'cake':
      return `
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7">
          <path stroke="none" d="M0 0h24v24H0z" fill="none" />
          <path d="M3 20h18v-8a3 3 0 0 0 -3 -3h-12a3 3 0 0 0 -3 3v8z" />
          <path d="M3 14.803c.312 .135 .654 .197 1 .197a2.4 2.4 0 0 0 2 -1a2.4 2.4 0 0 1 2 -1a2.4 2.4 0 0 1 2 1a2.4 2.4 0 0 0 2 1a2.4 2.4 0 0 0 2 -1a2.4 2.4 0 0 1 2 -1a2.4 2.4 0 0 1 2 1a2.4 2.4 0 0 0 2 1c.346 0 .688 -.062 1 -.197" />
          <path d="M12 4l0 2" />
          <path d="M12 3a1 1 0 0 1 1 1v1a1 1 0 0 1 -1 1a1 1 0 0 1 -1 -1v-1a1 1 0 0 1 1 -1z" />
        </svg>
      `;
    case 'music':
      return `
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7">
          <path stroke="none" d="M0 0h24v24H0z" fill="none" />
          <path d="M3 17a3 3 0 1 0 6 0a3 3 0 1 0 -6 0" />
          <path d="M13 15a3 3 0 1 0 6 0a3 3 0 1 0 -6 0" />
          <path d="M9 17v-13h10v11" />
          <path d="M9 8l10 -2" />
        </svg>
      `;
    case 'sleep':
      return `
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7">
          <path stroke="none" d="M0 0h24v24H0z" fill="none" />
          <path d="M12 3c.132 0 .263 0 .393 0a7.5 7.5 0 0 0 7.92 12.446a9 9 0 1 1 -8.313 -12.454z" />
          <path d="M17 4a2 2 0 0 0 2 2a2 2 0 0 0 -2 2a2 2 0 0 0 -2 -2a2 2 0 0 0 2 -2z" />
          <path d="M19 11h2m-1 -1v2" />
        </svg>
      `;
    case 'bell':
      return `
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7">
          <path stroke="none" d="M0 0h24v24H0z" fill="none" />
          <path d="M10 5a2 2 0 0 1 4 0a7 7 0 0 1 4 6v3a4 4 0 0 0 2 3h-16a4 4 0 0 0 2 -3v-3a7 7 0 0 1 4 -6" />
          <path d="M9 17a3 3 0 0 0 6 0" />
          <path d="M21 6.72a9 9 0 0 0 -5.67 -4.56" />
          <path d="M3 6.72a9 9 0 0 1 5.67 -4.56" />
        </svg>
      `;
    default:
      return `
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7">
          <path stroke="none" d="M0 0h24v24H0z" fill="none" />
          <path d="M12 20l-7.5 -7.428a5 5 0 1 1 7.5 -6.566a5 5 0 1 1 7.5 6.572" />
        </svg>
      `;
  }
};
---

<section id="schedule" class="py-20 px-4 md:px-8 bg-brand-bg max-w-5xl mx-auto border-b border-brand-title/5">
  <div class="text-center max-w-2xl mx-auto mb-16 space-y-3">
    <h2 class="font-wedding text-5xl md:text-6xl text-brand-title">Program</h2>
    <div class="w-12 h-[1px] bg-brand-title/30 mx-auto"></div>
    <p class="font-sans text-xs uppercase tracking-widest text-brand-text/80 font-medium">Slik ser bryllupsdagen ut</p>
  </div>

  <!-- Timeline List -->
  <div class="space-y-6 max-w-3xl mx-auto relative pl-12 md:pl-0">
    
    <!-- Vertical line connecting timeline events (for md+ centered, for mobile left aligned) -->
    <div class="absolute left-6 md:left-24 top-2 bottom-2 w-[1px] bg-brand-title/15"></div>

    {weddingConfig.schedule.map((event) => (
      <div class="relative flex flex-col md:flex-row md:items-start group py-4">
        
        <!-- Time marker (Desktop: Left, Mobile: Absolute next to icon) -->
        <div class="hidden md:block w-20 text-right pr-6 pt-2 font-serif text-xl text-brand-title font-semibold select-none group-hover:text-brand-text transition-colors">
          {event.time}
        </div>

        <!-- Timeline Node (Icon container) -->
        <div class="absolute left-0 md:left-[84px] top-4 md:top-1 w-12 h-12 rounded-full bg-brand-bg border border-brand-title/30 flex items-center justify-center text-brand-title z-10 shadow-xs group-hover:bg-brand-title group-hover:text-brand-bg transition-all duration-500 group-hover:scale-105">
          <Fragment set:html={getIconSvg(event.icon)} />
        </div>

        <!-- Content Card -->
        {event.title === 'Egentid' ? (
          <a href="#egentid" class="ml-14 md:ml-12 flex-1 bg-brand-bg/50 p-5 rounded-lg border border-brand-title/5 hover:border-brand-title/30 hover:bg-brand-bg/90 transition-all duration-300 block group/card cursor-pointer">
            <!-- Mobile time display -->
            <div class="md:hidden font-serif text-lg text-brand-title font-semibold mb-1 select-none">
              {event.time}
            </div>
            <h3 class="font-serif text-xl text-brand-title font-semibold mb-2 group-hover:text-brand-text transition-colors flex items-center gap-1.5">
              <span>{event.title}</span>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5 text-brand-title/70 group-hover/card:translate-x-0.5 transition-transform">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </h3>
            <p class="font-sans text-sm leading-relaxed text-brand-text/85 font-light">
              {event.description}
            </p>
            <span class="text-xs font-semibold text-brand-title group-hover/card:underline block mt-3">Les våre nabolagsanbefalinger &rarr;</span>
          </a>
        ) : (
          <div class="ml-14 md:ml-12 flex-1 bg-brand-bg/50 p-5 rounded-lg border border-brand-title/5 hover:border-brand-title/20 hover:bg-brand-bg/90 transition-all duration-300">
            <!-- Mobile time display -->
            <div class="md:hidden font-serif text-lg text-brand-title font-semibold mb-1 select-none">
              {event.time}
            </div>
            <h3 class="font-serif text-xl text-brand-title font-semibold mb-2 group-hover:text-brand-text transition-colors">
              {event.title}
            </h3>
            <p class="font-sans text-sm leading-relaxed text-brand-text/85 font-light">
              {event.description}
            </p>
          </div>
        )}

      </div>
    ))}
  </div>
</section>
