---
import { env } from 'cloudflare:workers';
import { weddingConfig } from '../config';
import { fetchScheduleFromNotion } from '../services/notion';

interface Props {
  flags: Record<string, boolean>;
}

const { flags } = Astro.props;
let schedule = weddingConfig.schedule;

// Retrieve Cloudflare runtime context
const cloudflareContext = Astro.locals?.cfContext;

try {
  const notionSchedule = await fetchScheduleFromNotion(env as Env, cloudflareContext);
  if (notionSchedule && notionSchedule.length > 0) {
    schedule = notionSchedule;
  }
} catch (err) {
  console.error("Failed to load program from Notion, falling back to static config:", err);
}

---

<section id="schedule" class="py-20 px-4 md:px-8 bg-brand-bg max-w-5xl mx-auto border-b border-brand-title/5">
  <div class="text-center max-w-2xl mx-auto mb-16 space-y-3">
    <h2>Program</h2>
    <div class="w-12 h-[1px] bg-brand-title/30 mx-auto"></div>
    <p class="text-lead">Slik ser bryllupsdagen ut</p>
  </div>

  <!-- Timeline List -->
  <div class="space-y-6 max-w-3xl mx-auto relative pl-12 md:pl-0">
    
    <!-- Vertical line connecting timeline events (for md+ centered, for mobile left aligned) -->
    <div class="absolute left-6 md:left-24 top-2 bottom-2 w-[1px] bg-brand-title/15"></div>

    {schedule.map((event) => (
      <div class="relative flex flex-col md:flex-row md:items-start group py-4">
        
        <!-- Time marker (Desktop: Left, Mobile: Absolute next to icon) -->
        <div class="hidden md:block w-20 text-right pr-6 pt-2 font-serif text-xl text-brand-title font-semibold select-none group-hover:text-brand-text transition-colors">
          {event.time}
        </div>

        <!-- Timeline Node (Emoji container) -->
        <div class="absolute left-0 md:left-[84px] top-4 md:top-1 w-12 h-12 rounded-full bg-brand-bg border border-brand-title/30 flex items-center justify-center z-10 shadow-xs group-hover:bg-brand-title transition-all duration-500 group-hover:scale-105">
          <span class="schedule-emoji text-xl leading-none select-none" aria-hidden="true">{event.icon}</span>
        </div>

        <!-- Content Card -->
        {event.title && event.title.trim() === 'Egentid' ? (
          <a href="#egentid" class="ml-14 md:ml-12 flex-1 bg-brand-bg/50 p-5 rounded-lg border border-brand-title/5 hover:border-brand-title/30 hover:bg-brand-bg/90 transition-all duration-300 block group/card cursor-pointer">
            <!-- Mobile time display -->
            <div class="md:hidden font-serif text-lg text-brand-title font-semibold mb-1 select-none">
              {event.time}
            </div>
            <h3 class="text-xl mb-2 group-hover:text-brand-text transition-colors flex items-center gap-1.5">
              <span>{event.title}</span>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5 text-brand-title/70 group-hover/card:translate-x-0.5 transition-transform">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </h3>
            <p class="text-body">
              {event.description}
            </p>
            <span class="text-xs font-semibold text-brand-title group-hover/card:underline block mt-3">Les våre nabolagsanbefalinger &rarr;</span>
          </a>
        ) : (
          <div class="ml-14 md:ml-12 flex-1 bg-brand-bg/50 p-5 rounded-lg border border-brand-title/5 hover:border-brand-title/20 hover:bg-brand-bg/90 transition-all duration-300">
            <!-- Mobile time display -->
            <div class="md:hidden font-serif text-lg text-brand-title font-semibold mb-1 select-none">
              {event.time}
            </div>
            <h3 class="text-xl mb-2 group-hover:text-brand-text transition-colors">
              {event.title}
            </h3>
            <p class="text-body">
              {event.description}
            </p>
            {flags.map && event.locationId && (
              <a
                href={`/kart?loc=${event.locationId}`}
                class="inline-flex items-center gap-1.5 text-xs font-semibold text-brand-title hover:text-brand-text hover:underline mt-3 select-none transition-colors"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.75"
                  stroke="currentColor"
                  class="w-3.5 h-3.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"
                  />
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M19.5 10.5c0 7.14-7.5 11.25-7.5 11.25S4.5 17.64 4.5 10.5a7.5 7.5 0 1 1 15 0z"
                  />
                </svg>
                <span>Se kart</span>
              </a>
            )}
          </div>
        )}

      </div>
    ))}
  </div>
</section>
