---
import { weddingConfig } from '../config';

// Helper to return custom SVG paths based on icon identifier
const getIconSvg = (iconName?: string) => {
  switch (iconName) {
    case 'ring':
      return `
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.25" stroke="currentColor" class="w-7 h-7">
          <circle cx="9" cy="12" r="5" stroke="currentColor" />
          <circle cx="15" cy="12" r="5" stroke="currentColor" />
          <path stroke-linecap="round" d="M12 7.5L12 9.5M12 14.5L12 16.5" stroke="currentColor" />
        </svg>
      `;
    case 'glass':
      return `
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.25" stroke="currentColor" class="w-7 h-7">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 9.75l4.5 4.5m0-4.5l-4.5 4.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18c3-4 6-4 9 0M10.5 6L8.5 4M13.5 6l2-2" />
          <line x1="8" y1="19" x2="16" y2="19" stroke="currentColor" />
        </svg>
      `;
    case 'food':
      return `
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.25" stroke="currentColor" class="w-7 h-7">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 12.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 18.75a.75.75 0 110-1.5.75.75 0 010 1.5z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 6.75h10.5v10.5H6.75z" />
        </svg>
      `;
    case 'cake':
      return `
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.25" stroke="currentColor" class="w-7 h-7">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
          <path d="M12 3v3" stroke="currentColor" stroke-linecap="round" />
        </svg>
      `;
    case 'music':
      return `
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.25" stroke="currentColor" class="w-7 h-7">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 9l10.5-3v12m-10.5-9v12m0-12l-6 1.5v12" />
          <circle cx="6" cy="17" r="3" stroke="currentColor" />
          <circle cx="16" cy="15" r="3" stroke="currentColor" />
        </svg>
      `;
    default:
      return `
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.25" stroke="currentColor" class="w-7 h-7">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
        </svg>
      `;
  }
};
---

<section id="schedule" class="py-20 px-4 md:px-8 bg-brand-bg max-w-5xl mx-auto border-b border-brand-title/5">
  <div class="text-center max-w-2xl mx-auto mb-16 space-y-3">
    <h2 class="font-wedding text-5xl md:text-6xl text-brand-title">Program</h2>
    <div class="w-12 h-[1px] bg-brand-title/30 mx-auto"></div>
    <p class="font-sans text-xs uppercase tracking-widest text-brand-text/80 font-medium">Slik ser bryllupsdagen ut</p>
  </div>

  <!-- Timeline List -->
  <div class="space-y-6 max-w-3xl mx-auto relative pl-12 md:pl-0">
    
    <!-- Vertical line connecting timeline events (for md+ centered, for mobile left aligned) -->
    <div class="absolute left-6 md:left-24 top-2 bottom-2 w-[1px] bg-brand-title/15"></div>

    {weddingConfig.schedule.map((event) => (
      <div class="relative flex flex-col md:flex-row md:items-start group py-4">
        
        <!-- Time marker (Desktop: Left, Mobile: Absolute next to icon) -->
        <div class="hidden md:block w-20 text-right pr-6 pt-2 font-serif text-xl text-brand-title font-semibold select-none group-hover:text-brand-text transition-colors">
          {event.time}
        </div>

        <!-- Timeline Node (Icon container) -->
        <div class="absolute left-0 md:left-[84px] top-4 md:top-1 w-12 h-12 rounded-full bg-brand-bg border border-brand-title/30 flex items-center justify-center text-brand-title z-10 shadow-xs group-hover:bg-brand-title group-hover:text-brand-bg transition-all duration-500 group-hover:scale-105">
          <Fragment set:html={getIconSvg(event.icon)} />
        </div>

        <!-- Content Card -->
        <div class="md:ml-12 flex-1 bg-brand-bg/50 p-5 rounded-lg border border-brand-title/5 hover:border-brand-title/20 hover:bg-brand-bg/90 transition-all duration-300">
          <!-- Mobile time display -->
          <div class="md:hidden font-serif text-lg text-brand-title font-semibold mb-1 select-none">
            {event.time}
          </div>
          <h3 class="font-serif text-xl text-brand-title font-semibold mb-2 group-hover:text-brand-text transition-colors">
            {event.title}
          </h3>
          <p class="font-sans text-sm leading-relaxed text-brand-text/85 font-light">
            {event.description}
          </p>
        </div>

      </div>
    ))}
  </div>
</section>
