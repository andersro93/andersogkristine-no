---
import { weddingConfig } from '../config';
---

<section id="story" class="py-20 px-4 md:px-8 bg-brand-bg/40 max-w-6xl mx-auto border-b border-brand-title/5">
  <div class="text-center max-w-2xl mx-auto mb-16 space-y-3">
    <h2 class="font-wedding text-5xl md:text-6xl text-brand-title">Vår Historie</h2>
    <div class="w-12 h-[1px] bg-brand-title/30 mx-auto"></div>
    <p class="font-sans text-xs uppercase tracking-widest text-brand-text/80 font-medium">Veien til hverandre</p>
  </div>

  <div class="relative">
    <!-- Center line (desktop only) -->
    <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-[1px] bg-brand-title/20 -translate-x-1/2"></div>

    <div class="space-y-12 md:space-y-20">
      {weddingConfig.story.map((item, index) => {
        const isEven = index % 2 === 0;
        return (
          <div class={`relative flex flex-col md:flex-row items-stretch ${isEven ? 'md:flex-row-reverse' : ''}`}>
            
            <!-- Timeline node -->
            <div class="absolute left-4 md:left-1/2 top-6 -translate-x-1/2 w-4 h-4 rounded-full bg-brand-bg border-2 border-brand-title z-10 shadow-xs">
              <div class="w-1.5 h-1.5 rounded-full bg-brand-text m-auto mt-0.5"></div>
            </div>

            <!-- Content Card (Left or Right depending on alignment) -->
            <div class="w-full md:w-1/2 pl-10 md:pl-0 md:px-12 flex">
              <div class="flex-1 bg-brand-bg p-6 md:p-8 rounded-xl border border-brand-title/10 shadow-xs hover:shadow-md transition-all duration-300 group hover:-translate-y-0.5">
                <span class="font-serif text-3xl md:text-4xl text-brand-title/60 font-semibold block mb-2 group-hover:text-brand-title transition-colors">
                  {item.year}
                </span>
                <h3 class="font-serif text-2xl md:text-3xl text-brand-title font-semibold mb-3">
                  {item.title}
                </h3>
                <p class="font-sans text-sm leading-relaxed text-brand-text/95 font-light">
                  {item.content}
                </p>
              </div>
            </div>

            <!-- Empty spacer for desktop layout balance -->
            <div class="hidden md:block w-1/2"></div>
            
          </div>
        );
      })}
    </div>
  </div>
</section>
