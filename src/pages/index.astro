---
import { env } from 'cloudflare:workers';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import OurStory from '../components/OurStory.astro';
import Schedule from '../components/Schedule.astro';
import Egentid from '../components/Egentid.astro';
import Location from '../components/Location.astro';
import PracticalInfo from '../components/PracticalInfo.astro';
import Footer from '../components/Footer.astro';
import { fetchFeatureFlags } from '../services/notion';

const context = Astro.locals?.runtime?.ctx;
let flags = { rsvp: true, seating: true, music: true, map: true, egentid: true, program: true };
try {
  const fetchedFlags = await fetchFeatureFlags(env as Env, context);
  if (fetchedFlags) {
    flags = fetchedFlags;
  }
} catch (err) {
  console.error("Failed to load feature flags in homepage:", err);
}
---

<Layout>
  <main class="overflow-x-hidden min-h-screen">
    <Hero flags={flags} />
    <PracticalInfo flags={flags} />
    {flags.program && <Schedule flags={flags} />}
    {flags.egentid && <Egentid />}
    {flags.map && <Location />}
    <OurStory />
    <Footer flags={flags} />
  </main>
</Layout>
