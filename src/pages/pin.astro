---
import Layout from '../layouts/Layout.astro';
import { weddingConfig } from '../config';

const errorParam = Astro.url.searchParams.get('error');
let initialError = '';
if (errorParam === 'invalid_invite') {
  initialError = 'Ugyldig invitasjonskode. Vennligst tast inn PIN-koden for å få tilgang.';
} else if (errorParam === 'verification_error') {
  initialError = 'Det oppstod en feil ved verifisering av invitasjonskoden. Vennligst prøv igjen med PIN-koden.';
}
---

<Layout title="Adgangskontroll - Kristine & Anders">
  <main class="min-h-screen py-16 px-4 md:px-8 max-w-xl mx-auto flex flex-col justify-center select-none">
    
    <!-- Header -->
    <div class="text-center mb-10 animate-fade-in">
      <h1 class="font-wedding text-5xl md:text-6xl text-brand-title mb-2">
        {weddingConfig.names.bride} <span class="font-sans text-2xl font-light italic opacity-95">{weddingConfig.names.ampersand}</span> {weddingConfig.names.groom}
      </h1>
      <p class="font-serif italic text-lg opacity-90 text-brand-text/80">Velkommen til vårt bryllup</p>
      <div class="w-24 h-px bg-brand-title/20 mx-auto mt-6"></div>
    </div>

    <!-- PIN Card -->
    <div class="bg-[#fcfbf9]/85 backdrop-blur-md border border-brand-title/10 rounded-2xl p-8 md:p-12 shadow-xl shadow-brand-title/5 relative overflow-hidden animate-fade-in">
      
      <!-- Corner ornaments -->
      <div class="absolute top-0 left-0 w-8 h-8 border-t-2 border-l-2 border-brand-title/10 rounded-tl-xl"></div>
      <div class="absolute top-0 right-0 w-8 h-8 border-t-2 border-r-2 border-brand-title/10 rounded-tr-xl"></div>
      <div class="absolute bottom-0 left-0 w-8 h-8 border-b-2 border-l-2 border-brand-title/10 rounded-bl-xl"></div>
      <div class="absolute bottom-0 right-0 w-8 h-8 border-b-2 border-r-2 border-brand-title/10 rounded-br-xl"></div>

      <div class="text-center py-6">
        <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-brand-title/5 text-brand-title mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
          </svg>
        </div>

        <h2 class="font-serif text-2xl text-brand-title mb-3">Tast inn adgangskode</h2>
        <p class="font-sans text-sm text-brand-text/70 max-w-sm mx-auto mb-8 leading-relaxed">
          Nettstedet er passordbeskyttet. Vennligst oppgi PIN-koden du finner i invitasjonen for å se innholdet.
        </p>

        <!-- Error Container -->
        <div id="error-message" class={initialError ? "bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6 text-sm font-sans transition-all duration-300" : "hidden bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6 text-sm font-sans transition-all duration-300"}>
          {initialError}
        </div>

        <!-- Form -->
        <form id="pin-form" class="space-y-4 max-w-sm mx-auto">
          <div class="relative">
            <input 
              type="password" 
              name="pin" 
              id="pin-input"
              required
              maxlength="32"
              placeholder="••••" 
              class="w-full px-4 py-3 rounded-lg border border-brand-title/20 bg-white font-sans text-brand-title focus:outline-none focus:ring-2 focus:ring-brand-title/50 text-center tracking-widest text-xl font-semibold"
            />
          </div>

          <button 
            type="submit" 
            id="submit-btn"
            class="w-full bg-brand-title text-brand-bg hover:bg-brand-title/90 px-8 py-3 rounded-lg font-sans font-medium transition duration-300 hover:shadow-lg focus:outline-none focus:ring-2 focus:ring-brand-title flex items-center justify-center gap-2"
          >
            <span id="btn-text">Åpne bryllupsside</span>
            <svg id="loading-spinner" class="hidden animate-spin h-5 w-5 text-brand-bg" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
          </button>
        </form>
      </div>

    </div>
  </main>
</Layout>

<script>
  const form = document.getElementById('pin-form') as HTMLFormElement;
  const input = document.getElementById('pin-input') as HTMLInputElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text');
  const spinner = document.getElementById('loading-spinner');
  const errorDiv = document.getElementById('error-message');

  if (form && input && submitBtn) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      // Clear previous error
      if (errorDiv) {
        errorDiv.classList.add('hidden');
        errorDiv.innerText = '';
      }

      // Start loading state
      input.disabled = true;
      submitBtn.disabled = true;
      if (btnText) btnText.innerText = 'Verifiserer...';
      if (spinner) spinner.classList.remove('hidden');

      try {
        const res = await fetch('/api/validate-pin', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ pin: input.value })
        });

        const data = await res.json();

        if (res.ok && data.success) {
          // Success: redirect to target or homepage
          const urlParams = new URLSearchParams(window.location.search);
          const next = urlParams.get('next') || '/';
          window.location.href = next;
        } else {
          // Error response
          throw new Error(data.error || 'Ugyldig PIN-kode.');
        }
      } catch (err: any) {
        // Reset inputs and display error
        input.disabled = false;
        submitBtn.disabled = false;
        if (btnText) btnText.innerText = 'Åpne bryllupsside';
        if (spinner) spinner.classList.add('hidden');
        input.value = '';
        input.focus();

        if (errorDiv) {
          errorDiv.innerText = err.message;
          errorDiv.classList.remove('hidden');
        }
      }
    });
  }
</script>
