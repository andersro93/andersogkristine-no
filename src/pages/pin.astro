---
import { useState } from 'react';
---

<div class="min-h-screen flex items-center justify-center bg-brand-bg">
  <form class="bg-brand-bg/80 p-8 rounded-lg shadow-lg max-w-sm w-full" onSubmit={(e) => {
    e.preventDefault();
    const pin = (e.target as any).pin.value;
    fetch('/api/validate-pin', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ pin }),
    })
      .then(res => {
        if (res.ok) return res.json();
        throw new Error('Invalid PIN');
      })
      .then(() => window.location.href = '/')
      .catch(err => alert(err.message));
  }}>
    <h2 class="text-2xl font-wedding text-brand-title mb-4 text-center">Enter Access PIN</h2>
    <input type="password" name="pin" required class="w-full px-4 py-2 rounded border border-brand-title/20 focus:outline-none focus:ring-2 focus:ring-brand-title mb-4" placeholder="PIN code"/>
    <button type="submit" class="w-full bg-brand-title text-brand-bg hover:bg-brand-title/90 py-2.5 rounded font-sans font-medium transition">Enter</button>
  </form>
</div>
