---
import { env } from 'cloudflare:workers';
import Layout from '../layouts/Layout.astro';
import RSVPForm from '../components/RSVPForm';
import { fetchInviteByCode, type Invite } from '../services/notion';
import { weddingConfig } from '../config';

// Server-side invite lookup
const code = Astro.url.searchParams.get('code');
let invite: Invite | null = null;
let errorMsg: string | null = null;

if (code) {
  try {
    invite = await fetchInviteByCode(code, env as Env);
    if (!invite) {
      errorMsg = "Ugyldig invitasjonskode. Vennligst sjekk at koden stemmer.";
    }
  } catch (err) {
    console.error("Error fetching invite in page:", err);
    errorMsg = "Det oppstod en feil ved henting av din invitasjon. Vennligst prøv igjen.";
  }
}
---

<Layout title="Svar på invitasjon - Kristine og Anders">
  <main class="min-h-screen py-16 px-4 md:px-8 max-w-3xl mx-auto flex flex-col justify-center">
    
    <!-- Header -->
    <div class="text-center mb-10">
      <a href="/" class="inline-block mb-4 text-sm tracking-wider uppercase text-brand-title hover:underline opacity-80">&larr; Tilbake til forsiden</a>
      <h1 class="mb-2">Svar på invitasjon</h1>
      <p class="text-body-serif">Svarfrist: 1. juni 2026</p>
      <div class="w-24 h-px bg-brand-title/20 mx-auto mt-6"></div>
    </div>

    <!-- MAIN CARD -->
    <div class="bg-[#fcfbf9]/85 backdrop-blur-md border border-brand-title/10 rounded-2xl p-8 md:p-12 shadow-xl shadow-brand-title/5 relative overflow-hidden">
      
      <!-- Corner ornaments -->
      <div class="absolute top-0 left-0 w-8 h-8 border-t-2 border-l-2 border-brand-title/10 rounded-tl-xl"></div>
      <div class="absolute top-0 right-0 w-8 h-8 border-t-2 border-r-2 border-brand-title/10 rounded-tr-xl"></div>
      <div class="absolute bottom-0 left-0 w-8 h-8 border-b-2 border-l-2 border-brand-title/10 rounded-bl-xl"></div>
      <div class="absolute bottom-0 right-0 w-8 h-8 border-b-2 border-r-2 border-brand-title/10 rounded-br-xl"></div>

      {!invite ? (
        /* State A: Code entry form (no JS needed — plain HTML form GET) */
        <div class="text-center py-6">
          {errorMsg && (
            <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6 text-sm font-sans">
              {errorMsg}
            </div>
          )}
          
          <h3 class="mb-4">Vennligst oppgi din invitasjonskode</h3>
          <p class="text-caption max-w-md mx-auto mb-8">
            For å kunne svare elektronisk må du skrive inn den unike koden som står i invitasjonen du har mottatt.
          </p>

          <form method="GET" action="/rsvp" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
            <input 
              type="text" 
              name="code" 
              required
              placeholder="F.eks. LILO2026" 
              class="flex-1 px-4 py-3 rounded-lg border border-brand-title/20 bg-white font-sans text-brand-title focus:outline-none focus:ring-2 focus:ring-brand-title/50 text-center uppercase tracking-widest text-lg font-medium"
              value={code || ""}
            />
            <button 
              type="submit" 
              class="bg-brand-title text-brand-bg hover:bg-brand-title/90 px-8 py-3 rounded-lg font-sans font-medium transition duration-300 hover:shadow-lg focus:outline-none focus:ring-2 focus:ring-brand-title"
            >
              Finn invitasjon
            </button>
          </form>
        </div>
      ) : (
        /* State B: React island handles all the interactive form logic */
        <RSVPForm invite={invite} client:load />
      )}

    </div>
  </main>
</Layout>
